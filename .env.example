# ─── JSONBin.io Data Sync (Recommended) ───────────────────────────────────────
# Set these two variables to enable real-time data sync across all devices.
# 1. Go to https://jsonbin.io/app/bins  → copy your Bin ID
# 2. Go to https://jsonbin.io/app/account/apikeys → copy your X-Master-Key

VITE_JSONBIN_BIN_ID=69ef2309856a6821897909da
VITE_JSONBIN_API_KEY=your_x_master_key_here

# ─── Generic REST Sync (Advanced / Alternative) ────────────────────────────────
# If you prefer a different backend (e.g. a custom API), set these instead.
# VITE_SHARED_STATE_URL=https://your-api-endpoint.example.com/state
# VITE_SHARED_STATE_TOKEN=your_bearer_token_here
# VITE_SHARED_STATE_METHOD=PUT
